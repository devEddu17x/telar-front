              "application/json": {
                "schema": { "$ref": "#/components/schemas/OrderEntity" }
              }
            }
          }
        },
        "summary": "Cancel order by ID",
        "tags": ["Order"]
      }
    },
    "/api/v1/tenant/setup": {
      "post": {
        "operationId": "TenantController_setupTenant",
        "parameters": [],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/CreateTenantDto" }
            }
          }
        },
        "responses": {
          "default": {
            "description": "",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/TenantEntity" }
              }
            }
          }
        },
        "summary": "Setup a new tenant",
        "tags": ["Tenant"]
      }
    },
    "/api/v1/tenant/{id}": {
      "get": {
        "operationId": "TenantController_getTenant",
        "parameters": [
          {
            "name": "id",
            "required": true,
            "in": "path",
            "schema": { "type": "string" }
          }
        ],
        "responses": {
          "default": {
            "description": "",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/TenantEntity" }
              }
            }
          }
        },
        "summary": "Get tenant information by ID",
        "tags": ["Tenant"]
      }
    }
  },
  "info": {
    "title": "Telar API",
    "description": "API documentation for the Telar application",
    "version": "1.0.0",
    "contact": {}
  },
  "tags": [],
  "servers": [],
  "components": {
    "securitySchemes": {
      "bearer": { "scheme": "bearer", "bearerFormat": "JWT", "type": "http" }
    },
    "schemas": {
      "CreateOwnerDTO": {
        "type": "object",
        "properties": {
          "name": { "type": "string", "maxLength": 64 },
          "lastName": { "type": "string", "maxLength": 64 },
          "email": { "type": "string", "maxLength": 64, "format": "email" },
          "password": {
            "type": "string",
            "minLength": 12,
            "pattern": "^(?=.*[a-z])(?=.*[A-Z])(?=.*\\d)(?=.*[\\W_]).{12,}$"
          }
        },
        "required": ["name", "lastName", "email", "password"]
      },
      "TenantEntity": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "name": { "type": "string" },
          "ruc": { "type": "string" },
          "address": { "type": "string" },
          "createdAt": { "format": "date-time", "type": "string" },
          "updatedAt": { "format": "date-time", "type": "string" }
        },
        "required": ["id", "name", "ruc", "address", "createdAt", "updatedAt"]
      },
      "EmployeeEntity": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "sub": { "type": "string" },
          "names": { "type": "string" },
          "lastNames": { "type": "string" },
          "email": { "type": "string" },
          "isActive": { "type": "boolean" },
          "tenantId": { "type": "string" },
          "tenant": { "$ref": "#/components/schemas/TenantEntity" },
          "createdAt": { "format": "date-time", "type": "string" },
          "updatedAt": { "format": "date-time", "type": "string" }
        },
        "required": [
          "id",
          "sub",
          "names",
          "lastNames",
          "email",
          "isActive",
          "createdAt",
          "updatedAt"
        ]
      },
      "ConfirmEmailDTO": {
        "type": "object",
        "properties": {
          "email": { "type": "string", "format": "email" },
          "code": { "type": "string", "minLength": 6, "maxLength": 6 }
        },
        "required": ["email", "code"]
      },
      "ResendCodeDTO": {
        "type": "object",
        "properties": { "email": { "type": "string", "format": "email" } },
        "required": ["email"]
      },
      "LoginDTO": {
        "type": "object",
        "properties": {
          "email": { "type": "string", "format": "email" },
          "password": { "type": "string" }
        },
        "required": ["email", "password"]
      },
      "UpdateEmployeeDTO": {
        "type": "object",
        "properties": {
          "names": { "type": "string", "maxLength": 64 },
          "lastNames": { "type": "string", "maxLength": 64 }
        }
      },
      "CreateCustomerDTO": {
        "type": "object",
        "properties": {
          "names": { "type": "string", "maxLength": 100 },
          "lastNames": { "type": "string", "maxLength": 100 },
          "reference": { "type": "string", "maxLength": 100 },
          "phone": {
            "type": "string",
            "minLength": 9,
            "maxLength": 9,
            "pattern": "^9\\d{8}$"
          }
        },
        "required": ["names", "lastNames"]
      },
      "CustomerEntity": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "tenantId": { "type": "string" },
          "tenant": { "$ref": "#/components/schemas/TenantEntity" },
          "names": { "type": "string" },
          "lastNames": { "type": "string" },
          "reference": { "type": "string" },
          "phone": { "type": "string" },
          "email": { "type": "string" },
          "isEcommerceUser": { "type": "boolean" },
          "createdAt": { "format": "date-time", "type": "string" },
          "updatedAt": { "format": "date-time", "type": "string" },
          "quotes": {
            "type": "array",
            "items": { "$ref": "#/components/schemas/QuoteEntity" }
          }
        },
        "required": [
          "id",
          "tenantId",
          "names",
          "lastNames",
          "reference",
          "phone",
          "email",
          "isEcommerceUser",
          "createdAt",
          "updatedAt",
          "quotes"
        ]
      },
      "ClotheImageEntity": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "tenantId": { "type": "string" },
          "url": { "type": "string" },
          "clothesId": { "type": "string" },
          "clothes": { "$ref": "#/components/schemas/ClothesEntity" }
        },
        "required": ["id", "tenantId", "url", "clothesId", "clothes"]
      },
      "ClothesEntity": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "tenantId": { "type": "string" },
          "tenant": { "$ref": "#/components/schemas/TenantEntity" },
          "name": { "type": "string" },
          "description": { "type": "string" },
          "price": { "type": "number" },
          "isInEcommerce": { "type": "boolean" },
          "isDraft": { "type": "boolean" },
          "createdAt": { "format": "date-time", "type": "string" },
          "updatedAt": { "format": "date-time", "type": "string" },
          "deletedAt": { "format": "date-time", "type": "string" },
          "clothes_variant": {
            "type": "array",
            "items": { "$ref": "#/components/schemas/ClothesVariantEntity" }
          },
          "clothe_image": {
            "type": "array",
            "items": { "$ref": "#/components/schemas/ClotheImageEntity" }
          }
        },
        "required": [
          "id",
          "tenantId",
          "name",
          "description",
          "price",
          "isInEcommerce",
          "isDraft",
          "createdAt",
          "updatedAt",
          "deletedAt",
          "clothes_variant",
          "clothe_image"
        ]
      },
      "SizeEntity": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "size": {
            "type": "string",
            "enum": [
              "2",
              "4",
              "6",
              "8",
              "10",
              "12",
              "14",
              "16",
              "XS",
              "S",
              "M",
              "L",
              "XL",
              "XXL",
              "XXXL"
            ]
          }
        },
        "required": ["id", "size"]
      },
      "GenderEntity": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "gender": { "type": "string", "enum": ["HOMBRE", "MUJER", "UNISEX"] }
        },
        "required": ["id", "gender"]
      },
      "ClothesVariantEntity": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "tenantId": { "type": "string" },
          "clothesId": { "type": "string" },
          "clothes": { "$ref": "#/components/schemas/ClothesEntity" },
          "sizeId": { "type": "string" },
          "size": { "$ref": "#/components/schemas/SizeEntity" },
          "genderId": { "type": "string" },
          "gender": { "$ref": "#/components/schemas/GenderEntity" },
          "additional": { "type": "number" },
          "quoteDetails": {
            "type": "array",
            "items": { "$ref": "#/components/schemas/QuoteDetailEntity" }
          }
        },
        "required": [
          "id",
          "tenantId",
          "clothesId",
          "clothes",
          "sizeId",
          "size",
          "genderId",
          "gender",
          "additional",
          "quoteDetails"
        ]
      },
      "QuoteDetailEntity": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "tenantId": { "type": "string" },
          "tenant": { "$ref": "#/components/schemas/TenantEntity" },
          "unitPrice": { "type": "number" },
          "quantity": { "type": "number" },
          "customizations": { "type": "array", "items": { "type": "string" } },
          "quoteId": { "type": "string" },
          "quote": { "$ref": "#/components/schemas/QuoteEntity" },
          "clothesVariantId": { "type": "string" },
          "clothesVariant": {
            "$ref": "#/components/schemas/ClothesVariantEntity"
          }
        },
        "required": [
          "id",
          "tenantId",
          "unitPrice",
          "quantity",
          "customizations",
          "quoteId",
          "quote",
          "clothesVariantId",
          "clothesVariant"
        ]
      },
      "QuoteEntity": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "tenantId": { "type": "string" },
          "tenant": { "$ref": "#/components/schemas/TenantEntity" },
          "total": { "type": "number" },
          "customerId": { "type": "string" },
          "customer": { "$ref": "#/components/schemas/CustomerEntity" },
          "status": {
            "enum": ["PENDING", "APPROVED", "REJECTED", "CANCELLED"],
            "type": "string"
          },
          "details": {
            "type": "array",
            "items": { "$ref": "#/components/schemas/QuoteDetailEntity" }
          },
          "createdAt": { "format": "date-time", "type": "string" },
          "updatedAt": { "format": "date-time", "type": "string" },
          "deletedAt": { "format": "date-time", "type": "string" }
        },
        "required": [
          "id",
          "tenantId",
          "total",
          "customerId",
          "customer",
          "status",
          "details",
          "createdAt",
          "updatedAt",
          "deletedAt"
        ]
      },
      "UpdateCustomerDTO": {
        "type": "object",
        "properties": {
          "reference": { "type": "string", "maxLength": 100 },
          "phone": {
            "type": "string",
            "minLength": 9,
            "maxLength": 9,
            "pattern": "^9\\d{8}$"
          }
        },
        "required": ["reference", "phone"]
      },
      "Variant": {
        "type": "object",
        "properties": {
          "gender": { "enum": ["HOMBRE", "MUJER", "UNISEX"], "type": "string" },
          "size": {
            "enum": [
              "2",
              "4",
              "6",
              "8",
              "10",
              "12",
              "14",
              "16",
              "XS",
              "S",
              "M",
              "L",
              "XL",
              "XXL",
              "XXXL"
            ],
            "type": "string"
          },
          "additional": { "type": "number", "minimum": 0 }
        },
        "required": ["gender", "size", "additional"]
      },
      "AllowedImagesDTO": {
        "type": "object",
        "properties": {
          "filename": { "type": "string" },
          "contentType": {
            "type": "string",
            "enum": ["image/jpeg", "image/png", "image/webp", "image/avif"]
          }
        },
        "required": ["filename", "contentType"]
      },
      "CreateClothesDTO": {
        "type": "object",
        "properties": {
          "name": { "type": "string" },
          "description": { "type": "string" },
          "price": { "type": "number", "minimum": 0, "maximum": 1000 },
          "variants": {
            "type": "array",
            "items": { "$ref": "#/components/schemas/Variant" }
          },
          "images": {
            "type": "array",
            "items": { "$ref": "#/components/schemas/AllowedImagesDTO" }
          }
        },
        "required": ["name", "description", "price", "variants", "images"]
      },
      "CreateDraftClothesDTO": {
        "type": "object",
        "properties": {
          "name": { "type": "string" },
          "price": { "type": "number", "minimum": 0 },
          "images": {
            "type": "array",
            "items": { "$ref": "#/components/schemas/AllowedImagesDTO" }
          }
        },
        "required": ["name", "price", "images"]
      },
      "UpdateClothesDTO": {
        "type": "object",
        "properties": {
          "name": { "type": "string" },
          "description": { "type": "string" },
          "price": { "type": "number", "minimum": 0 },
          "isInEcommerce": { "type": "boolean" },
          "isDraft": { "type": "boolean" }
        }
      },
      "UpdateVariantDTO": {
        "type": "object",
        "properties": { "additional": { "type": "number", "minimum": 0 } },
        "required": ["additional"]
      },
      "AddImagesToClothesDTO": {
        "type": "object",
        "properties": {
          "images": {
            "type": "array",
            "items": { "$ref": "#/components/schemas/AllowedImagesDTO" }
          }
        },
        "required": ["images"]
      },
      "DeleteImageDTO": {
        "type": "object",
        "properties": { "url": { "type": "string", "format": "uri" } },
        "required": ["url"]
      },
      "EmployeeRoleUpdateDTO": {
        "type": "object",
        "properties": {
          "email": { "type": "string", "format": "email" },
          "role": { "enum": ["owner", "admin", "seller"], "type": "string" }
        },
        "required": ["email", "role"]
      },
      "CreateEmployeeDTO": {
        "type": "object",
        "properties": {
          "email": { "type": "string", "maxLength": 64, "format": "email" },
          "names": { "type": "string", "maxLength": 64 },
          "lastNames": { "type": "string", "maxLength": 64 },
          "role": { "type": "string", "enum": ["admin", "seller"] }
        },
        "required": ["email", "names", "lastNames", "role"]
      },
      "CustomizationDTO": {
        "type": "object",
        "properties": {
          "name": { "type": "string" },
          "number": { "type": "number", "minimum": 0, "maximum": 100 },
          "notes": { "type": "string" }
        }
      },
      "QuoteDetailDTO": {
        "type": "object",
        "properties": {
          "clothesVariantId": { "type": "string", "format": "uuid" },
          "quantity": { "type": "number", "minimum": 1, "maximum": 100000 },
          "customizations": {
            "maxItems": 100,
            "type": "array",
            "items": { "$ref": "#/components/schemas/CustomizationDTO" }
          }
        },
        "required": ["clothesVariantId", "quantity"]
      },
      "CreateQuoteDTO": {
        "type": "object",
        "properties": {
          "details": {
            "type": "array",
            "items": { "$ref": "#/components/schemas/QuoteDetailDTO" }
          },
          "customerId": { "type": "string", "format": "uuid" }
        },
        "required": ["details", "customerId"]
      },
      "UpdateQuoteDTO": {
        "type": "object",
        "properties": {
          "details": {
            "type": "array",
            "items": { "$ref": "#/components/schemas/QuoteDetailDTO" }
          }
        },
        "required": ["details"]
      },
      "AddressDTO": {
        "type": "object",
        "properties": {
          "department": { "type": "string", "maxLength": 100 },
          "city": { "type": "string", "maxLength": 100 },
          "district": { "type": "string", "maxLength": 100 },
          "street": { "type": "string", "maxLength": 255 }
        },
        "required": ["department", "city", "district", "street"]
      },
      "CreateOrderDTO": {
        "type": "object",
        "properties": {
          "quoteId": { "type": "string", "format": "uuid" },
          "address": { "$ref": "#/components/schemas/AddressDTO" },
          "deliveryDate": { "type": "string" }
        },
        "required": ["quoteId", "address", "deliveryDate"]
      },
      "AddressEntity": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "department": { "type": "string" },
          "city": { "type": "string" },
          "district": { "type": "string" },
          "street": { "type": "string" },
          "tenantId": { "type": "string" },
          "tenant": { "$ref": "#/components/schemas/TenantEntity" }
        },
        "required": [
          "id",
          "department",
          "city",
          "district",
          "street",
          "tenantId",
          "tenant"
        ]
      },
      "OrderEntity": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "total": { "type": "number" },
          "status": {
            "enum": ["IN_PRODUCTION", "DONE", "CANCELLED"],
            "type": "string"
          },
          "createdAt": { "format": "date-time", "type": "string" },
          "cancellationReason": { "type": "string", "nullable": true },
          "deliveryDate": { "format": "date-time", "type": "string" },
          "quoteId": { "type": "string" },
          "quote": { "$ref": "#/components/schemas/QuoteEntity" },
          "addressId": { "type": "string" },
          "address": { "$ref": "#/components/schemas/AddressEntity" },
          "tenantId": { "type": "string" },
          "tenant": { "$ref": "#/components/schemas/TenantEntity" },
          "updatedAt": { "format": "date-time", "type": "string" },
          "deletedAt": { "format": "date-time", "type": "string" }
        },
        "required": [
          "id",
          "total",
          "status",
          "createdAt",
          "cancellationReason",
          "deliveryDate",
          "quoteId",
          "quote",
          "addressId",
          "address",
          "tenantId",
          "tenant",
          "updatedAt",
          "deletedAt"
        ]
      },
      "UpdateOrderDTO": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string",
            "enum": ["IN_PRODUCTION", "DONE", "CANCELLED"]
          }
        },
        "required": ["status"]
      },
      "CancelOrderDTO": {
        "type": "object",
        "properties": { "reason": { "type": "string", "maxLength": 500 } },
        "required": ["reason"]
      },
      "CreateTenantDto": {
        "type": "object",
        "properties": {
          "name": { "type": "string", "maxLength": 100 },
          "ruc": { "type": "string", "pattern": "^(10|20)\\d{9}$" },
          "address": { "type": "string", "maxLength": 256 }
        },
        "required": ["name"]
      }
    }
  }
}
